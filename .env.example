# ─── Firebase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project credentials.
# NEVER commit .env.local to version control.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="Soda La Rustica"
VITE_APP_ENV=development

# ─── Multi-Tenant ─────────────────────────────────────────────────────────────
# In production, tenant ID is resolved from subdomain or QR param.
# For local dev, override manually.
VITE_DEV_TENANT_ID=soda-la-rustica
